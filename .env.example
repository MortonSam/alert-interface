# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=alert
POSTGRES_PASSWORD=alert
POSTGRES_DB=alertdb

# async driver (used by FastAPI)
DATABASE_URL=postgresql+asyncpg://alert:alert@db:5432/alertdb
# sync driver (used by Alembic)
DATABASE_URL_SYNC=postgresql+psycopg2://alert:alert@db:5432/alertdb

# ── FastAPI ───────────────────────────────────────────────
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
DEBUG=true
CORS_ORIGINS=http://localhost:3000
ADMIN_TOKEN=
REFRESH_ENABLED=true

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Finnhub ──────────────────────────────────────────────
FINNHUB_API_KEY=

# ── Polygon.io (free tier) ────────────────────────────────
POLYGON_API_KEY=

# ── FRED (St. Louis Fed) ──────────────────────────────────
FRED_API_KEY=

# ── ntfy.sh push notifications ────────────────────────────
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
